# Core
PORT=5000
NODE_ENV=development
MONGODB_URL=mongodb://127.0.0.1:27017/aidoctor
JWT_SECRET=replace-with-a-strong-random-secret

# Frontend origins (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173

# Optional rate limiting override
RATE_LIMIT_MAX=300

# AI provider
GROQ_API_KEY=

# RAG retrieval
HF_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=standard-treatment-guidelines_-pdf
PINECONE_NAMESPACES=standard-treatment-guidelines_-pdf
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
GOOGLE_FRONTEND_REDIRECT_URL=http://localhost:5173/oauth-success

# RAG ingestion script options
PDF_PATH=./standard-treatment-guidelines_.pdf
MIN_CHUNK_LENGTH=20
PINECONE_UPSERT_BATCH_SIZE=100
